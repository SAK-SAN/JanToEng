# ==========================================
# セキュリティ：絶対に秘密にすべき環境変数ファイル
# ==========================================
.env
.env.local
.env.*

# ==========================================
# Python：実行時に自動生成される不要なキャッシュ
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Streamlit：ローカル実行時の設定ファイル
# ==========================================
.streamlit/config.toml

# ==========================================
# OS：MacやWindowsが勝手に作成する隠しファイル
# ==========================================
.DS_Store
Thumbs.db